# Demo auth (hardcoded fallback: admin/admin)
DEMO_USERNAME=admin
DEMO_PASSWORD=admin

# Supabase (wired for auth persistence in future)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# LLM provider keys — book §4.3 Stage 3 multi-model strategy
# (blank = pipeline falls back to bundled mock outputs)
#
# ANTHROPIC_API_KEY  → Stage 4 code generation (primary, book §7.B)
# OPENAI_API_KEY     → Stage 2 spec consolidation pass (book §4.3 Stage 3)
# GOOGLE_API_KEY     → Stage 1 parsing + Stage 2 draft + Stage 4 fallback
# PINECONE_API_KEY   → Stage 3 RAG (currently inline; Pinecone integration TBD)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX=iso-19450-v1

# Cloud deploy (optional bonus stage).
# Credentials are now per-user, not server-wide:
#   • GitHub  — each user connects via OAuth (button in the dashboard).
#   • Railway — each user pastes their own API token (railway.app/account/tokens)
#               in the dashboard; no server-side Railway client needed.
#
# GitHub OAuth App — create at github.com/settings/developers → OAuth Apps.
# Register the callback URL as <base-url>/api/auth/github/callback.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Public base URL used to build the OAuth redirect URI (dev + prod).
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Pipeline timeouts (ms) — raise for large/complex inputs (e.g. multi-page PDFs).
# Per-call timeouts bound each model call, so generous stage budgets can't hang.
#   OPM_PARSE_TIMEOUT_MS    → Stage 1 parse budget per file (default 300000 = 5 min).
#   OPM_GENERATE_TIMEOUT_MS → Stage 4 code-gen budget (default 1800000 = 30 min; complex models make many calls).
#   OPM_VALIDATE_TIMEOUT_MS → Stage 5 validate + QA budget (default 600000 = 10 min).
#   OPM_LLM_CALL_TIMEOUT_MS → hard cap per individual model call (default 240000 = 4 min).
#   OPM_JOB_TIMEOUT_MS      → upstream auto-expire for the whole job; MUST exceed the sum
#                             of the stage budgets (default 3600000 = 60 min).
OPM_PARSE_TIMEOUT_MS=300000
OPM_GENERATE_TIMEOUT_MS=1800000
OPM_VALIDATE_TIMEOUT_MS=600000
OPM_LLM_CALL_TIMEOUT_MS=240000
OPM_JOB_TIMEOUT_MS=3600000
