# Copy this file to web/.env.local and fill in the values.
# .env.local is gitignored — your real keys never get committed.

# Demo auth (the /api/login route checks these; fallback admin/admin)
DEMO_USERNAME=admin
DEMO_PASSWORD=admin

# ── LLM provider keys ──────────────────────────────────────────────────────
# Blank = the pipeline falls back to bundled mock outputs (UI works, but it's
# not the real agent). Set BOTH of these to run the real generate<->test loop:
#   GOOGLE_API_KEY     → Stage 1 parse + Stage 2 spec + Stage 3 super-prompt
#                        + the Testing Agent's acceptance tests (Tier 4).
#   ANTHROPIC_API_KEY  → Stage 4 code generation (the two-agent build loop).
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=

# Note: RAG is inline (ISO-19450 rules injected at Stage 3 from knowledge/);
# there is no vector DB to configure. OpenAI is no longer used.

# Supabase (optional — only for the signup flow; demo login above does not need it)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Cloud deploy (optional bonus). GitHub via OAuth, Railway via a per-user token
# pasted in the dashboard. Create the OAuth App at github.com/settings/developers
# and register <base-url>/api/auth/github/callback as the callback URL.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Pipeline timeouts (ms) — all have defaults; raise for large/complex inputs.
#   OPM_PARSE_TIMEOUT_MS    → Stage 1 parse budget per file (default 300000 = 5 min).
#   OPM_GENERATE_TIMEOUT_MS → Stage 4 loop budget (default 1800000 = 30 min).
#   OPM_VALIDATE_TIMEOUT_MS → Stage 5 validate + QA budget (default 600000 = 10 min).
#   OPM_LLM_CALL_TIMEOUT_MS → hard cap per individual model call (default 240000 = 4 min).
#   OPM_JOB_TIMEOUT_MS      → whole-job auto-expire; MUST exceed the stage budgets (default 3600000 = 60 min).
OPM_PARSE_TIMEOUT_MS=300000
OPM_GENERATE_TIMEOUT_MS=1800000
OPM_VALIDATE_TIMEOUT_MS=600000
OPM_LLM_CALL_TIMEOUT_MS=240000
OPM_JOB_TIMEOUT_MS=3600000
